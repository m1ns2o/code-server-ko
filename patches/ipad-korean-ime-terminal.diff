+			return composeSyllable(this._leading, this._medial, this._trailing);
+		}
+		return this._leading + this._medial + this._trailing;
+	}
+}
+
+function isLeading(char: string): boolean {
+	return leadingConsonants.includes(char);
+}
+
+function isMedial(char: string): boolean {
+	return medialVowels.includes(char);
+}
+
+function isTrailing(char: string): boolean {
+	return trailingConsonants.includes(char);
+}
+
+function composeSyllable(leading: string, medial: string, trailing: string): string {
+	const leadingIndex = leadingConsonants.indexOf(leading);
+	const medialIndex = medialVowels.indexOf(medial);
+	const trailingIndex = trailingConsonants.indexOf(trailing);
+	if (leadingIndex === -1 || medialIndex === -1 || trailingIndex === -1) {
+		return leading + medial + trailing;
+	}
+	return String.fromCharCode(0xAC00 + ((leadingIndex * 21) + medialIndex) * 28 + trailingIndex);
+}
+
+function decomposeHangulSyllable(char: string): string[] | undefined {
+	const codePoint = char.charCodeAt(0);
+	if (codePoint < 0xAC00 || codePoint > 0xD7A3) {
+		return undefined;
+	}
+
+	const syllableIndex = codePoint - 0xAC00;
+	const trailingIndex = syllableIndex % 28;
+	const medialIndex = Math.floor(syllableIndex / 28) % 21;
+	const leadingIndex = Math.floor(syllableIndex / 28 / 21);
+	const trailing = trailingConsonants[trailingIndex];
+	return [
+		leadingConsonants[leadingIndex],
+		...expandMedial(medialVowels[medialIndex]),
+		...expandTrailing(trailing)
+	];
+}
+
+function expandMedial(medial: string): string[] {
+	return splitCompoundMedials.get(medial) ?? [medial];
+}
+
+function expandTrailing(trailing: string): string[] {
+	if (!trailing) {
+		return [];
+	}
+	return splitCompoundTrail.get(trailing) ?? [trailing];
+}
+
+function startsWithJamo(value: string[], prefix: string[]): boolean {
+	if (prefix.length > value.length) {
+		return false;
+	}
+	for (let i = 0; i < prefix.length; i++) {
+		if (value[i] !== prefix[i]) {
+			return false;
+		}
+	}
+	return true;
+}
